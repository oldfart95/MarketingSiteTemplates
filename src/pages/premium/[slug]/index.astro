---
import PremiumLayout from '../../../layouts/PremiumLayout.astro';
import { getPremiumBusiness, premiumBusinesses } from '../../../data/premium';
import { sitePath } from '../../../lib/paths';
export function getStaticPaths() { return premiumBusinesses.map((business) => ({ params: { slug: business.slug } })); }
const business = getPremiumBusiness(Astro.params.slug!); if (!business) return Astro.redirect(sitePath());
const basePath = sitePath(`premium/${business.slug}`);
---
<PremiumLayout business={business} pageTitle={`${business.businessName} | ${business.city}`}>
  <section class="hero premium-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">{business.templateType === 'professional' ? 'Advisory firm' : business.niche} in {business.city}</p>
        <h1>{business.tagline}</h1>
        <p class="lead">{business.premium.promise}</p>
        <div class="action-row">
          <a href={`${basePath}/contact`} class="button button--solid">{business.primaryCTA}</a>
          <a href={`${basePath}/pricing`} class="button button--ghost">Review service options</a>
        </div>
        <div class="trust-row">
          {business.premium.highlights.map((highlight) => <span>{highlight}</span>)}
        </div>
      </div>
      <div class="hero-media premium-dashboard">
        <img src={business.galleryImages[0].src} alt={business.galleryImages[0].alt} loading="eager" />
        <div class="mini-panel mini-panel--top">
          <strong>{business.services.length} service paths</strong>
          <span>{business.services.map((service) => service.name).join(' · ')}</span>
        </div>
        <div class="hero-note">
          <strong>{business.primaryCTA}</strong>
          <span>{business.phone} · {business.city}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Why clients choose us</p>
        <h2>Clear answers before the first conversation</h2>
        <p>{business.problemSolved}</p>
      </div>
      <div class="card-grid premium-feature-grid">
        {business.objections.map((item) => (
          <article class="feature-card">
            <h3>{item.concern}</h3>
            <p>{item.response}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div>
        <p class="eyebrow">Core services</p>
        <h2>Clear pathways for high-intent visitors</h2>
        <p class="body-copy">{business.idealClient}</p>
      </div>
      <div class="stack-list">
        {business.services.map((service) => (
          <a class="stack-item" href={`${basePath}/services`}>
            <strong>{service.name}</strong>
            <span>{service.description}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--compact section--surface">
    <div class="container stat-strip">
      <div><strong>{business.serviceArea.length}</strong><span>local areas served</span></div>
      <div><strong>{business.services.length}</strong><span>primary services</span></div>
      <div><strong>{business.premium.resources.length}</strong><span>helpful resources</span></div>
    </div>
  </section>
</PremiumLayout>
