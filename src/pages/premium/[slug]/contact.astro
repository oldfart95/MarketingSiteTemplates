---
import PremiumLayout from '../../../layouts/PremiumLayout.astro';
import { getPremiumBusiness, premiumBusinesses } from '../../../data/premium';
export function getStaticPaths() { return premiumBusinesses.map((business) => ({ params: { slug: business.slug } })); }
const business = getPremiumBusiness(Astro.params.slug!); if (!business) return Astro.redirect('/');
---
<PremiumLayout business={business} pageTitle={`Contact | ${business.businessName}`}>
  <section class="page-hero">
    <div class="container narrow">
      <p class="eyebrow">Contact</p>
      <h1>Start with a focused request.</h1>
      <p class="lead">Share what is happening, where you are located, and the best way to follow up.</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid premium-contact-grid">
      <form class="intake-form" method="get" action={`mailto:${business.email}`}>
        <label>
          Name
          <input name="name" type="text" autocomplete="name" />
        </label>
        <label>
          Email
          <input name="email" type="email" autocomplete="email" />
        </label>
        <label>
          Phone
          <input name="phone" type="tel" autocomplete="tel" />
        </label>
        <label>
          What do you need help with?
          <select name="service">
            {business.services.map((service) => <option>{service.name}</option>)}
          </select>
        </label>
        <label>
          Message
          <textarea name="message" rows="5"></textarea>
        </label>
        <button class="button button--solid" type="submit">{business.primaryCTA}</button>
      </form>

      <aside class="detail-panel contact-sidebar">
        <div>
          <span>Call</span>
          <strong><a href={`tel:${business.phone}`}>{business.phone}</a></strong>
        </div>
        <div>
          <span>Email</span>
          <strong><a href={`mailto:${business.email}`}>{business.email}</a></strong>
        </div>
        <div>
          <span>Hours</span>
          <strong>{business.premium.hours}</strong>
        </div>
        <div>
          <span>Serving</span>
          <strong>{business.serviceArea.join(', ')}</strong>
        </div>
      </aside>
    </div>
  </section>
</PremiumLayout>
