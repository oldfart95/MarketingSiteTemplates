---
import PremiumLayout from '../../../layouts/PremiumLayout.astro';
import { getPremiumBusiness, premiumBusinesses } from '../../../data/premium';
import { getFormAttributes, getFormSettings, getMailtoHref } from '../../../lib/forms';
export function getStaticPaths() { return premiumBusinesses.map((business) => ({ params: { slug: business.slug } })); }
const business = getPremiumBusiness(Astro.params.slug!); if (!business) return Astro.redirect('/');
const formSettings = getFormSettings();
const formAttributes = getFormAttributes(formSettings);
const fallbackEmail = formSettings.intakeEmail || business.email;
const hasEndpoint = Boolean(formSettings.formActionUrl);
const hasFallbackEmail = Boolean(fallbackEmail);
---
<PremiumLayout business={business} pageTitle={`Contact | ${business.businessName}`}>
  <section class="page-hero">
    <div class="container narrow">
      <p class="eyebrow">Contact</p>
      <h1>Start with a focused request.</h1>
      <p class="lead">Share what is happening, where you are located, and the best way to follow up.</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid premium-contact-grid">
      <form class="intake-form" name="premium-contact" {...formAttributes}>
        <input type="hidden" name="form-name" value="premium-contact" />
        <input type="hidden" name="form-provider" value={formSettings.formProviderName || 'configured-endpoint'} />
        {hasEndpoint ? (
          <p class="form-status">{formSettings.formProviderName ? `Submits through ${formSettings.formProviderName}.` : 'Submits through the configured form endpoint.'} {formSettings.formSuccessMessage}</p>
        ) : (
          <p class="form-status form-status--fallback">
            {formSettings.formFallbackMessage}
            {hasFallbackEmail && <span> Email <a href={getMailtoHref(fallbackEmail, `${business.businessName} request`)}>{fallbackEmail}</a> with these details.</span>}
          </p>
        )}
        <label>
          Name
          <input name="name" type="text" autocomplete="name" />
        </label>
        <label>
          Email
          <input name="email" type="email" autocomplete="email" />
        </label>
        <label>
          Phone
          <input name="phone" type="tel" autocomplete="tel" />
        </label>
        <label>
          What do you need help with?
          <select name="service">
            {business.services.map((service) => <option>{service.name}</option>)}
          </select>
        </label>
        <label>
          Message
          <textarea name="message" rows="5"></textarea>
        </label>
        <button class="button button--solid" type={hasEndpoint ? 'submit' : 'button'}>{hasEndpoint ? business.primaryCTA : 'Prepare Request'}</button>
      </form>

      <aside class="detail-panel contact-sidebar">
        <div>
          <span>Call</span>
          <strong><a href={`tel:${business.phone}`}>{business.phone}</a></strong>
        </div>
        <div>
          <span>Email</span>
          <strong><a href={`mailto:${business.email}`}>{business.email}</a></strong>
        </div>
        <div>
          <span>Hours</span>
          <strong>{business.premium.hours}</strong>
        </div>
        <div>
          <span>Serving</span>
          <strong>{business.serviceArea.join(', ')}</strong>
        </div>
      </aside>
    </div>
  </section>
</PremiumLayout>
