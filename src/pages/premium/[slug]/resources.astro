---
import PremiumLayout from '../../../layouts/PremiumLayout.astro';
import { getPremiumBusiness, premiumBusinesses } from '../../../data/premium';
export function getStaticPaths() { return premiumBusinesses.map((business) => ({ params: { slug: business.slug } })); }
const business = getPremiumBusiness(Astro.params.slug!); if (!business) return Astro.redirect('/');
---
<PremiumLayout business={business} pageTitle={`Resources | ${business.businessName}`}>
  <section class="page-hero">
    <div class="container narrow">
      <p class="eyebrow">Resources</p>
      <h1>Give visitors something useful before they call</h1>
      <p class="lead">A resource hub makes the business feel helpful, established, and easier to trust, even when the articles are short.</p>
    </div>
  </section>

  <section class="section">
    <div class="container resource-grid">
      {business.premium.resources.map((item) => (
        <article class="resource-card">
          <span>{item.category}</span>
          <h2>{item.title}</h2>
          <p>{item.description}</p>
          <a class="text-link" href={`/premium/${business.slug}/contact`}>Request this resource</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section section--compact section--surface">
    <div class="container split">
      <div>
        <p class="eyebrow">Lead magnet slot</p>
        <h2>Swap in checklists, guides, seasonal notices, or client FAQs</h2>
      </div>
      <p class="body-copy">This template stays static, but resource cards can link to PDFs, Google Docs, appointment pages, or simple mailto requests.</p>
    </div>
  </section>
</PremiumLayout>
