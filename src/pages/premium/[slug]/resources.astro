---
import PremiumLayout from '../../../layouts/PremiumLayout.astro';
import { getPremiumBusiness, premiumBusinesses } from '../../../data/premium';
import { sitePath } from '../../../lib/paths';
export function getStaticPaths() { return premiumBusinesses.map((business) => ({ params: { slug: business.slug } })); }
const business = getPremiumBusiness(Astro.params.slug!); if (!business) return Astro.redirect(sitePath());
const basePath = sitePath(`premium/${business.slug}`);
---
<PremiumLayout business={business} pageTitle={`Resources | ${business.businessName}`}>
  <section class="page-hero">
    <div class="container narrow">
      <p class="eyebrow">Resources</p>
      <h1>Helpful guidance before the first conversation.</h1>
      <p class="lead">These resources answer common questions and help visitors arrive with better context.</p>
    </div>
  </section>

  <section class="section">
    <div class="container resource-grid">
      {business.premium.resources.map((item) => (
        <article class="resource-card">
          <span>{item.category}</span>
          <h2>{item.title}</h2>
          <p>{item.description}</p>
          <a class="text-link" href={`${basePath}/contact`}>Request this resource</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section section--compact section--surface">
    <div class="container split">
      <div>
        <p class="eyebrow">Need help choosing?</p>
        <h2>Ask for the resource that fits your situation.</h2>
      </div>
      <p class="body-copy">A quick message helps the team point you toward the guide, checklist, or next conversation that makes the most sense.</p>
    </div>
  </section>
</PremiumLayout>
