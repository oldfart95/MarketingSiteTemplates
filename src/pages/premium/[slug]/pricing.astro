---
import PremiumLayout from '../../../layouts/PremiumLayout.astro';
import { getPremiumBusiness, premiumBusinesses } from '../../../data/premium';
import { sitePath } from '../../../lib/paths';
export function getStaticPaths() { return premiumBusinesses.map((business) => ({ params: { slug: business.slug } })); }
const business = getPremiumBusiness(Astro.params.slug!); if (!business) return Astro.redirect(sitePath());
const basePath = sitePath(`premium/${business.slug}`);
---
<PremiumLayout business={business} pageTitle={`Options | ${business.businessName}`}>
  <section class="page-hero">
    <div class="container narrow">
      <p class="eyebrow">Options</p>
      <h1>Compare common ways to begin.</h1>
      <p class="lead">These options help visitors understand fit before reaching out. Final recommendations depend on timing, details, and priorities.</p>
    </div>
  </section>

  <section class="section">
    <div class="container pricing-grid">
      {business.premium.packages.map((item) => (
        <article class="price-card">
          <p class="eyebrow">{item.price}</p>
          <h2>{item.name}</h2>
          <p>{item.description}</p>
          <ul>
            {item.features.map((feature) => <li>{feature}</li>)}
          </ul>
          <a href={`${basePath}/contact`} class="button button--solid">Ask about this</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section section--compact section--surface">
    <div class="container split">
      <div>
        <p class="eyebrow">Not sure?</p>
        <h2>Start with a short conversation.</h2>
      </div>
      <p class="body-copy">The team can help narrow the right next step after learning what is happening, where help is needed, and what deadline matters.</p>
    </div>
  </section>
</PremiumLayout>
