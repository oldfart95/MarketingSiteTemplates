---
import PremiumLayout from '../../../layouts/PremiumLayout.astro';
import { getPremiumBusiness, premiumBusinesses } from '../../../data/premium';
import { sitePath } from '../../../lib/paths';
export function getStaticPaths() { return premiumBusinesses.map((business) => ({ params: { slug: business.slug } })); }
const business = getPremiumBusiness(Astro.params.slug!); if (!business) return Astro.redirect(sitePath());
const basePath = sitePath(`premium/${business.slug}`);
---
<PremiumLayout business={business} pageTitle={`Services | ${business.businessName}`}>
  <section class="page-hero">
    <div class="container narrow">
      <p class="eyebrow">Services</p>
      <h1>Choose the right starting point with confidence</h1>
      <p class="lead">{business.problemSolved}</p>
    </div>
  </section>

  <section class="section">
    <div class="container service-list premium-service-list">
      {business.services.map((service, index) => (
        <article class="service-row">
          <span class="service-index">0{index + 1}</span>
          <div>
            <h2>{service.name}</h2>
            <p>{service.description}</p>
            <div class="tag-row">
              {business.trustPoints.slice(0, 3).map((point) => <span>{point}</span>)}
            </div>
          </div>
          <a href={`${basePath}/contact`} class="text-link">Start request</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section section--surface">
    <div class="container split">
      <div>
        <p class="eyebrow">Service area</p>
        <h2>Nearby support from {business.city.split(',')[0]}</h2>
        <p class="body-copy">Local clients want to know the business understands their area, their timing, and the kind of help they are asking for.</p>
      </div>
      <div class="area-grid">
        {business.serviceArea.map((area) => <a href={`${basePath}/contact`}>{area}</a>)}
      </div>
    </div>
  </section>
</PremiumLayout>
