---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businesses, getBusiness } from '../../../data/templates';
export function getStaticPaths() { return businesses.map((business) => ({ params: { slug: business.slug } })); }
const business = getBusiness(Astro.params.slug!); if (!business) return Astro.redirect('/');
---
<BaseLayout business={business} pageTitle={`About | ${business.businessName}`}>
  <section class="page-hero">
    <div class="container narrow">
      <p class="eyebrow">About & trust</p>
      <h1>A local business with a clear promise</h1>
      <p class="lead">{business.about}</p>
    </div>
  </section>
  <section class="section">
    <div class="container split">
      <div class="image-stack">
        {business.galleryImages.map((image) => <img src={image.src} alt={image.alt} loading="lazy" />)}
      </div>
      <div>
        <p class="eyebrow">What clients can count on</p>
        <h2>Confidence before the appointment</h2>
        <div class="check-list">
          {business.trustPoints.map((point) => <p><span></span>{point}</p>)}
        </div>
      </div>
    </div>
  </section>
  <section class="section section--compact section--surface">
    <div class="container stat-strip">
      <div><strong>{business.serviceArea.length}</strong><span>nearby communities served</span></div>
      <div><strong>{business.services.length}</strong><span>primary service paths</span></div>
      <div><strong>{business.testimonials.length}</strong><span>customer voices featured</span></div>
    </div>
  </section>
</BaseLayout>
