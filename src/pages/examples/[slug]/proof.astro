---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businesses, getBusiness } from '../../../data/templates';
export function getStaticPaths() { return businesses.map((business) => ({ params: { slug: business.slug } })); }
const business = getBusiness(Astro.params.slug!); if (!business) return Astro.redirect('/');
---
<BaseLayout business={business} pageTitle={`Proof | ${business.businessName}`}>
  <section class="page-hero">
    <div class="container narrow">
      <p class="eyebrow">Proof</p>
      <h1>Photos, reviews, and answers that reduce hesitation</h1>
      <p class="lead">Prospects can see the kind of work, care, or advisory experience they are asking for before they reach out.</p>
    </div>
  </section>
  <section class="section">
    <div class="container gallery-grid">
      {business.galleryImages.map((image) => (
        <figure>
          <img src={image.src} alt={image.alt} loading="lazy" />
          <figcaption>{image.alt}</figcaption>
        </figure>
      ))}
    </div>
  </section>
  <section class="section section--surface">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Customer words</p>
        <h2>What people notice after working with {business.businessName}</h2>
      </div>
      <div class="quote-grid">
        {business.testimonials.map((item) => (
          <blockquote>
            <p>"{item.quote}"</p>
            <footer>{item.name}</footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container faq-grid">
      {business.faqs.map((item) => (
        <article class="faq-card">
          <h3>{item.question}</h3>
          <p>{item.answer}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
