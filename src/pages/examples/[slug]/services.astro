---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businesses, getBusiness } from '../../../data/templates';
import { sitePath } from '../../../lib/paths';
export function getStaticPaths() { return businesses.map((business) => ({ params: { slug: business.slug } })); }
const business = getBusiness(Astro.params.slug!); if (!business) return Astro.redirect(sitePath());
const basePath = sitePath(`examples/${business.slug}`);
---
<BaseLayout business={business} pageTitle={`Services | ${business.businessName}`}>
  <section class="page-hero">
    <div class="container narrow">
      <p class="eyebrow">Services</p>
      <h1>Services designed around real local decisions</h1>
      <p class="lead">{business.problemSolved}</p>
    </div>
  </section>
  <section class="section">
    <div class="container service-list">
      {business.services.map((service, index) => (
        <article class="service-row">
          <span class="service-index">0{index + 1}</span>
          <div>
            <h2>{service.name}</h2>
            <p>{service.description}</p>
          </div>
          <a href={`${basePath}/contact`} class="text-link">Request details</a>
        </article>
      ))}
    </div>
  </section>
  <section class="section section--surface">
    <div class="container split">
      <div>
        <p class="eyebrow">Questions we answer early</p>
        <h2>Less uncertainty before the first call</h2>
      </div>
      <div class="trust-card-grid">
        {business.objections.map((item) => (
          <article class="trust-card">
            <strong>{item.concern}</strong>
            <p>{item.response}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
  <section class="section section--compact">
    <div class="container split">
      <div>
        <p class="eyebrow">Service area</p>
        <h2>Nearby help from {business.city.split(',')[0]}</h2>
      </div>
      <p class="body-copy">Serving {business.serviceArea.join(', ')} from {business.address}.</p>
    </div>
  </section>
</BaseLayout>
