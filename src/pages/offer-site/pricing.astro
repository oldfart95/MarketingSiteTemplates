---
import MarketingLayout from '../../layouts/MarketingLayout.astro';

const tiers = [
  {
    name: 'Starter Website',
    price: 'from $1,500',
    bestFor: 'Best for a small local business that needs a cleaner first impression and a direct path to calls or inquiries.',
    deliverables: [
      'Focused 3-page website structure',
      'Homepage, services, and contact/intake page',
      'Mobile-first layout and clear calls to action',
      'Basic service-area and local search copy',
      'Contact form layout and email handoff',
      'Static deployment setup'
    ]
  },
  {
    name: 'Professional Website Launch',
    price: 'from $3,500',
    bestFor: 'Best for an established business that needs stronger credibility, better service positioning, and a site that can support higher-value leads.',
    deliverables: [
      '4-5 core pages planned around buyer intent',
      'Copywriting structure for services, proof, objections, and FAQs',
      'Premium mobile and desktop design rhythm',
      'Local SEO basics for services and service areas',
      'Contact flow built around consultation requests',
      'Gallery or testimonial setup',
      'Deployment and one revision round'
    ]
  },
  {
    name: 'Monthly Care',
    price: 'from $150/month',
    bestFor: 'Best for owners who want their website kept current without opening a fresh project for every small change.',
    deliverables: [
      'Routine copy, photo, and service updates',
      'Small page edits and seasonal calls to action',
      'Basic uptime and link checks',
      'Light performance and accessibility review',
      'Monthly improvement recommendations',
      'Priority scheduling for future expansion'
    ]
  }
];
---
<MarketingLayout title="Pricing | Website Factory" description="Pricing tiers for Starter, Professional, and Monthly Care.">
  <section class="content-section"><div class="container prose">
    <p class="eyebrow">Clear packages for local businesses</p>
    <h1>Pricing that matches the level of trust your website needs to create.</h1>
    <p>Every project is scoped around the same outcome: make it easier for the right customer to understand your services, trust your business, and take the next step.</p>

    <div class="grid three-col">
      {tiers.map((tier) => (
        <article class="card">
          <p class="eyebrow">{tier.price}</p>
          <h2>{tier.name}</h2>
          <p>{tier.bestFor}</p>
          <h3>Included deliverables</h3>
          <ul>
            {tier.deliverables.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>


    <section class="comparison-section" aria-labelledby="starter-vs-professional">
      <p class="eyebrow">Starter Site vs. Professional Launch</p>
      <h2 id="starter-vs-professional">Starter gets you online credibly. Professional helps customers understand, trust, and choose you.</h2>
      <div class="comparison-grid">
        <article class="comparison-card starter">
          <h3>Starter Website</h3>
          <p>Best for businesses that need a clean, credible web presence quickly.</p>
          <ul>
            <li>4–5 core pages</li>
            <li>Basic service descriptions</li>
            <li>Mobile-friendly layout</li>
            <li>Contact page and call-to-action</li>
            <li>Basic local SEO structure</li>
            <li>Simple trust and credibility layout</li>
          </ul>
        </article>
        <article class="comparison-card professional">
          <h3>Professional Website Launch</h3>
          <p>Best for businesses that need the site to explain, persuade, and build trust.</p>
          <ul>
            <li>Expanded service copy</li>
            <li>Stronger homepage positioning</li>
            <li>FAQs that answer customer objections</li>
            <li>Testimonials or proof sections</li>
            <li>Gallery or before/after structure</li>
            <li>Service-area messaging</li>
            <li>More polished conversion flow</li>
            <li>Better suited for businesses trying to justify higher-value services</li>
          </ul>
        </article>
      </div>
    </section>

    <h2>How pricing is finalized</h2>
    <p>Final pricing is confirmed after intake based on page count, copy depth, asset readiness, special layout needs, and revision scope. You will know the project range before work begins.</p>
    <p><a class="button-primary" href="/offer-site/contact">Start Project Intake</a></p>
  </div></section>
</MarketingLayout>
