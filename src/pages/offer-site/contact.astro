---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { siteConfig } from '../../data/site';
---
<MarketingLayout title="Start Project | Website Factory" description="Start your website project with intake details.">
  <section class="content-section"><div class="container prose">
    <p class="eyebrow">Website launch review</p>
    <h1>Request a premium website consultation.</h1>
    <p>Share what is working, what feels dated, and what your next website needs to help customers do. This intake is designed for a focused launch conversation, not a generic quote form.</p>
    <p>Email intake fallback: <a href={`mailto:${siteConfig.intakeEmail}?subject=Website%20Launch%20Review`}>{siteConfig.intakeEmail}</a></p>

    <form aria-label="Website launch consultation request">
      <p><label>Your Name<br /><input type="text" name="name" autocomplete="name" required /></label></p>
      <p><label>Business Name<br /><input type="text" name="business" autocomplete="organization" required /></label></p>
      <p><label>Current Website<br /><input type="url" name="website" placeholder="https://example.com" /></label></p>
      <p><label>Package Interest<br />
        <select name="package">
          <option>Professional Website Launch - from $3,500</option>
          <option>Starter Website - from $1,500</option>
          <option>Monthly Care - from $150/month</option>
          <option>Not sure yet</option>
        </select>
      </label></p>
      <p><label>Timeline<br />
        <select name="timeline">
          <option>Ready to start this month</option>
          <option>Planning for the next 60 days</option>
          <option>Researching options</option>
        </select>
      </label></p>
      <p><label>What should the new site improve?<br /><textarea name="needs" rows="6" placeholder="Tell me about your services, ideal customers, current pain points, and what a successful launch would change." required></textarea></label></p>
      <p><label>Best Contact Method<br /><input type="text" name="contact" placeholder="Email, phone, or preferred next step" required /></label></p>
      <button type="submit" class="button-primary">Request Launch Review</button>
    </form>
  </div></section>
</MarketingLayout>
