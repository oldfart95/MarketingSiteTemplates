---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { offerSiteConfig } from '../../data/offer-site';

const intakeEmail = offerSiteConfig.intakeEmail.trim();
const intakeSubject = 'Website Launch Review';
---
<MarketingLayout title="Start Project | FrontDoor Web Co." description="Start a professional website launch for a local business.">
  <section class="content-section"><div class="container prose">
    <p class="eyebrow">Start Project Intake</p>
    <h1>Request a Website Launch Review</h1>
    <p>Share what is working, what feels dated, and what your next website needs to help customers do. This intake is designed for a focused launch conversation, not a generic quote form.</p>
    <p>
      Email intake fallback:
      {intakeEmail ? (
        <a href={`mailto:${intakeEmail}?subject=${encodeURIComponent(intakeSubject)}`}>{intakeEmail}</a>
      ) : (
        <span>Use the project intake form below</span>
      )}
    </p>
    <form aria-label="Website launch consultation request" class="intake-form">
      <label>Name<input type="text" name="name" required /></label>
      <label>Business Name<input type="text" name="business" required /></label>
      <label>Website or current online presence<input type="url" name="website" /></label>
      <label>Package Interest
        <select name="package">
          <option>Professional Website Launch - from $3,500</option>
          <option>Starter Credibility Site - from $1,500</option>
          <option>Custom Layout Build - from $7,000</option>
          <option>Monthly Care - from $150/month</option>
          <option>Not sure yet</option>
        </select>
      </label>
      <label>Timeline
        <select name="timeline">
          <option>Ready to start this month</option>
          <option>Planning for the next 60 days</option>
          <option>Researching options</option>
        </select>
      </label>
      <label>Do you already have website copy?
        <select name="copy-readiness">
          <option>Yes, mostly ready</option>
          <option>Some notes, but needs help</option>
          <option>No, I need copywriting help</option>
        </select>
      </label>
      <label>Main Services<textarea name="main-services" rows="4" placeholder="List the main services you want the site to explain." required></textarea></label>
      <label>Service Area<textarea name="service-area" rows="3" placeholder="Cities, neighborhoods, counties, or regions you serve." required></textarea></label>
      <label>Why Customers Choose You<textarea name="why-choose-you" rows="4" placeholder="Examples: responsiveness, clean work, licensed team, family-owned, specialized experience, warranties, or careful communication. Only include claims you can confirm."></textarea></label>
      <label>Common Customer Questions<textarea name="customer-questions" rows="4" placeholder="Questions prospects ask before hiring you, comparing options, or booking a quote."></textarea></label>
      <label>Proof Available<textarea name="proof-available" rows="4" placeholder="Reviews, photos, testimonials, certifications, licenses, before/after examples, or other trust proof."></textarea></label>
      <label>What should the new site improve?<textarea name="needs" rows="6" placeholder="Tell me about your services, ideal customers, current pain points, and what a successful launch would change." required></textarea></label>
      <label>Best Contact Method<input type="text" name="contact" placeholder="Email, phone, or preferred next step" required /></label>
      <button type="submit" class="button-primary">Request Launch Review</button>
    </form>
  </div></section>
</MarketingLayout>
