---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { sitePath } from '../../lib/paths';
---
<MarketingLayout title="Services | Website Factory" description="Professional website launch deliverables for local businesses.">
  <section class="content-section"><div class="container prose">
    <p class="eyebrow">Services</p>
    <h1>Professional Website Launch</h1>
    <p>A focused website package for local businesses that need a credible digital presence, stronger calls to action, and a launch path that does not require a complicated platform.</p>
  </div></section>

  <section class="content-section muted-bg">
    <div class="container card-grid">
      {['Home page strategy', 'Services page structure', 'About and trust messaging', 'Gallery or proof setup', 'Contact flow', 'Local SEO basics'].map((item) => (
        <article class="card premium-card"><h2>{item}</h2><p>Built around customer questions, local credibility, and a clear next step.</p></article>
      ))}
    </div>
  </section>

  <section class="content-section">
    <div class="container two-col">
      <div>
        <p class="eyebrow">Package anchor</p>
        <h2 id="professional-website-launch-3500">Professional Website Launch ($3,500)</h2>
        <p>Best for owners who need a polished 4-5 page website with copy direction, responsive design, deployment, and one revision round included.</p>
      </div>
      <div class="panel">
        <h2>Good fit when</h2>
        <ul>
          <li>Your current site feels dated or thin</li>
          <li>Your services are hard to compare</li>
          <li>You need trust proof, FAQs, and better calls to action</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="container comparison-section" aria-labelledby="starter-vs-pro-launch-services">
      <p class="eyebrow">Starter Site vs. Professional Launch</p>
      <h2 id="starter-vs-pro-launch-services">Starter gets you online credibly. Professional helps customers understand, trust, and choose you.</h2>
      <p class="comparison-intro">Starter is best when you need a clean presence quickly. Professional is built for businesses that need stronger messaging, proof, and a more persuasive path to inquiry.</p>
      <div class="comparison-grid">
        <article class="comparison-card starter">
          <h3>Starter Website</h3>
          <p>Best for businesses that need a clean, credible web presence quickly.</p>
          <ul>
            <li>4-5 core pages</li>
            <li>Basic service descriptions</li>
            <li>Mobile-friendly layout</li>
            <li>Contact page and call-to-action</li>
            <li>Basic local SEO structure</li>
            <li>Simple trust and credibility layout</li>
          </ul>
        </article>
        <article class="comparison-card professional">
          <h3>Professional Website Launch</h3>
          <p>Best for businesses that need the site to explain, persuade, and build trust.</p>
          <ul>
            <li>Expanded service copy</li>
            <li>Stronger homepage positioning</li>
            <li>FAQs that answer customer objections</li>
            <li>Testimonials or proof sections</li>
            <li>Gallery or before/after structure</li>
            <li>Service-area messaging</li>
            <li>More polished conversion flow</li>
            <li>Better suited for businesses trying to justify higher-value services</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="content-section care-band">
    <div class="container split">
      <h2>Ready for a launch plan?</h2>
      <a class="button-primary" href={sitePath('offer-site/contact')}>Start Project Intake</a>
    </div>
  </section>
</MarketingLayout>
