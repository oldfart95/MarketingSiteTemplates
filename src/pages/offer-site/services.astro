---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { sitePath } from '../../lib/paths';

const serviceGroups = [
  {
    title: 'Strategy',
    description: 'Clarify the audience, services, proof points, calls to action, and package fit before the page structure is built.',
    items: ['Homepage positioning', 'Service hierarchy', 'Trust and proof planning', 'Launch scope'],
  },
  {
    title: 'Website Build',
    description: 'Design and build clear, mobile-friendly pages that make the business easier to understand and contact.',
    items: ['4-5 core pages', 'Responsive layout', 'Gallery or proof setup', 'Contact flow'],
  },
  {
    title: 'Copywriting',
    description: 'Turn ready copy, rough notes, or interview answers into clear, truthful website copy that sounds professional and local.',
    items: ['Intake questions', 'Service descriptions', 'About/trust copy', 'FAQs and calls to action'],
  },
  {
    title: 'Launch',
    description: 'Prepare the site for a simple, low-maintenance launch with clean structure and final checks.',
    items: ['Static deployment', 'Metadata and page titles', 'Local service-area language', 'Pre-launch QA'],
  },
  {
    title: 'Ongoing Care',
    description: 'Keep the live site useful after launch with practical updates and priority support.',
    items: ['Small update batches', 'Photo swaps', 'Seasonal updates', 'Minor page improvements'],
  },
];
---
<MarketingLayout title="Services | FrontDoor Web Co." description="Professional website launch deliverables for local businesses.">
  <section class="content-section"><div class="container prose">
    <p class="eyebrow">Services</p>
    <h1>Website services for local businesses</h1>
    <p>Strategy, copy, design, launch, and care for local businesses that need to look credible, explain their services clearly, and make contact easy.</p>
  </div></section>

  <section class="content-section muted-bg">
    <div class="container service-group-grid">
      {serviceGroups.map((group) => (
        <article class="premium-card service-group-card">
          <h2>{group.title}</h2>
          <p>{group.description}</p>
          <ul>
            {group.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="content-section">
    <div class="container two-col">
      <div>
        <p class="eyebrow">Package anchor</p>
        <h2 id="professional-website-launch-3500">Professional Website Launch ($3,500)</h2>
        <p>Best for owners who need a polished 4-5 page website with copy direction, responsive design, deployment, and one revision round included.</p>
      </div>
      <div class="panel">
        <h2>Good fit when</h2>
        <ul>
          <li>Your current site feels dated or thin</li>
          <li>Your services are hard to compare</li>
          <li>You need trust proof, FAQs, and better calls to action</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="container prose">
      <p class="eyebrow">Local SEO basics</p>
      <h2>Clear structure, not ranking promises.</h2>
      <p>Local SEO basics means headings, page titles, service language, location context, clean metadata, and a fast static structure. It does not mean guaranteed Google rankings, ad management, or advanced SEO campaigns.</p>
    </div>
  </section>

  <section class="content-section muted-bg">
    <div class="container two-col">
      <div>
        <p class="eyebrow">Custom layout</p>
        <h2>Have a sketch or custom layout?</h2>
        <p>Bring the sketch, mood board, wireframe, or custom page structure. If the project needs custom design translation instead of the standard launch system, it belongs in the Custom Layout Build tier and may require extra review time.</p>
      </div>
      <div class="premium-card">
        <h3>What that service includes</h3>
        <p>Custom layout work covers homepage wireframing, section planning, design interpretation, responsive behavior, and additional QA so the final site still feels intentional on desktop and mobile.</p>
      </div>
    </div>
  </section>

  <section class="content-section care-band">
    <div class="container split">
      <h2>Ready for a launch plan?</h2>
      <a class="button-primary" href={sitePath('offer-site/contact')}>Request a Launch Plan</a>
    </div>
  </section>
</MarketingLayout>
