---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { businesses } from '../data/templates';
import { sitePath } from '../lib/paths';
---
<MarketingLayout title="Demo Library | FrontDoor Web Co." description="Case-study-style local business website examples.">
  <section class="content-section"><div class="container prose">
    <p class="eyebrow">Demo library</p>
    <h1>Sample builds for local business websites.</h1>
    <p>These are fictional demo businesses built to show structure, tone, and page depth. Use the Starter-style sample to judge the focused launch, then compare the Professional expanded site for deeper proof, resources, and service options.</p>
  </div></section>
  <section class="content-section muted-bg">
    <div class="container case-grid">
      {businesses.map((business) => (
        <article class="case-card">
          <img src={business.galleryImages[0].src} alt={business.galleryImages[0].alt} loading="lazy" />
          <p class="eyebrow">{business.niche}</p>
          <h2>{business.businessName}</h2>
          <p>{business.problemSolved}</p>
          <dl>
            <div><dt>Demo status</dt><dd>Fictional sample business</dd></div>
            <div><dt>Ideal client</dt><dd>{business.idealClient}</dd></div>
            <div><dt>Key pages</dt><dd>{business.keyPages.join(', ')}</dd></div>
          </dl>
          <div class="cta-row">
            <a class="button-primary" href={sitePath(`examples/${business.slug}/`)}>View Starter-style site</a>
            <a class="button-secondary" href={sitePath(`premium/${business.slug}/`)}>View Professional expanded site</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</MarketingLayout>
