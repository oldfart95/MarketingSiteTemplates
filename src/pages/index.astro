---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import PackageLadder from '../components/sections/PackageLadder.astro';
import { sitePath } from '../lib/paths';
import { copywritingOptions } from '../data/offer-site';

const includedItems = [
  {
    title: '4-5 core pages',
    description: 'Home, services, about/trust, proof or gallery, and contact pages arranged around how local customers actually decide.',
  },
  {
    title: 'Copywriting structure',
    description: 'Headlines, service descriptions, FAQs, and calls to action shaped from real business details.',
  },
  {
    title: 'Mobile-first design',
    description: 'Pages designed to be easy to read, tap, and contact from a phone.',
  },
  {
    title: 'Local SEO basics',
    description: 'Clear page titles, service language, location context, and clean structure for local search visibility.',
  },
  {
    title: 'Contact flow',
    description: 'Phone, form, service-area details, and next-step language placed where prospects need them.',
  },
  {
    title: 'Gallery and testimonial setup',
    description: 'A place for reviews, project photos, before/after examples, or trust proof.',
  },
  {
    title: 'Static deployment',
    description: 'Fast, low-maintenance pages that do not require a heavy backend.',
  },
  {
    title: 'One revision round',
    description: 'A focused review pass to correct facts, tighten copy, and polish layout before launch.',
  },
];

const processSteps = [
  {
    title: 'Intake',
    description: 'Confirm the package fit, current site problems, service priorities, assets, timeline, and any custom layout needs.',
  },
  {
    title: 'Draft',
    description: 'Build the first static version with page structure, copy direction, visual hierarchy, proof sections, and contact flow.',
  },
  {
    title: 'Review',
    description: 'Walk through the draft, collect one organized revision round, and tighten the parts that affect customer confidence.',
  },
  {
    title: 'Launch',
    description: 'Prepare metadata, deploy the static site, check mobile behavior, and make sure inquiry paths work as expected.',
  },
  {
    title: 'Care',
    description: 'Keep the site fresh with small edits, new photos, seasonal updates, page improvements, and priority support.',
  },
];
---
<MarketingLayout title="Professional Websites for Local Businesses | FrontDoor Web Co." description="Credible websites for local businesses people need to trust.">
  <section class="hero-section offer-hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Professional Website Launch - starting at $3,500</p>
        <h1>A credibility website built to turn local trust into calls.</h1>
        <p>We plan, write, design, and launch a polished static website for service businesses that need to look established, explain the offer clearly, and make the next step obvious.</p>
        <div class="cta-row">
          <a class="button-primary" href={sitePath('offer-site/contact')}>Start Project Intake</a>
          <a class="button-secondary" href={sitePath('demo-library/')}>See Premium Examples</a>
        </div>
      </div>
      <div class="panel premium-price-card">
        <span>Anchor package</span>
        <strong>Professional Website Launch</strong>
        <p>Starting at $3,500</p>
        <ul>
          <li>4-5 core pages</li>
          <li>Copy structure and conversion flow</li>
          <li>Deployment and one revision round</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="container section-heading">
      <p class="eyebrow">What is included</p>
      <h2>A complete launch package, not a pretty shell.</h2>
      <p>The work is scoped around the pieces a local business needs before a prospect trusts the call button.</p>
    </div>
    <div class="container card-grid">
      {includedItems.map((item) => (
        <article class="card premium-card"><h3>{item.title}</h3><p>{item.description}</p></article>
      ))}
    </div>
  </section>

  <PackageLadder />

  <section class="content-section muted-bg">
    <div class="container section-heading">
      <p class="eyebrow">Copywriting support</p>
      <h2>Need help with the words too?</h2>
      <p>Many local businesses do not have polished website copy ready. That is normal. The process can include a short intake or interview, service clarification, homepage messaging, service copy, FAQs, and calls to action.</p>
      <p>The goal is not fancy marketing language. It is clear, truthful, fact-checked copy that helps prospects understand, trust, and contact the business.</p>
    </div>
    <div class="container card-grid">
      {copywritingOptions.map((option) => (
        <article class="premium-card">
          <h3>{option.name}</h3>
          <p><strong>{option.bestFor}</strong></p>
          <p>{option.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="content-section">
    <div class="container two-col">
      <div>
        <p class="eyebrow">Custom layout</p>
        <h2>Have a sketch or custom layout?</h2>
        <p>Sketches, mood boards, and custom page structures are welcome. They move the project into the Custom Layout Build tier because the work requires custom design translation rather than the standard launch system.</p>
      </div>
      <div class="panel light-panel">
        <h3>Why it costs more</h3>
        <p>Custom layout work adds planning for page composition, responsive interpretation, edge cases across screen sizes, and extra QA before launch.</p>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="container comparison-section">
      <p class="eyebrow">Starter Credibility Site vs. Professional Launch</p>
      <h2>Starter makes you credible online. Professional helps customers understand, trust, and choose you.</h2>
      <p class="comparison-intro">If you need a premium web presence fast, Starter is the right move. If you need your website to explain higher-value work and reduce buyer hesitation, Professional is built for that job.</p>
      <div class="comparison-grid">
        <article class="comparison-card starter">
          <h3>Starter Credibility Site</h3>
          <p>Best for businesses that need a clean, credible web presence quickly.</p>
          <ul>
            <li>4-5 core pages</li>
            <li>Basic service descriptions</li>
            <li>Mobile-friendly layout</li>
            <li>Contact page and clear call-to-action</li>
            <li>Basic local SEO structure</li>
            <li>Simple trust and credibility layout</li>
          </ul>
        </article>
        <article class="comparison-card professional">
          <h3>Professional Website Launch</h3>
          <p>Best for businesses that need the site to explain, persuade, and build trust.</p>
          <ul>
            <li>Expanded service copy</li>
            <li>Stronger homepage positioning</li>
            <li>FAQs that answer customer objections</li>
            <li>Testimonials or proof sections</li>
            <li>Gallery or before/after structure</li>
            <li>Service-area messaging</li>
            <li>More polished conversion flow</li>
            <li>Better fit for higher-value services</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="content-section muted-bg">
    <div class="container comparison-grid">
      <article class="comparison-card comparison-card--weak">
        <p class="eyebrow">Weak online presence</p>
        <h2>Prospects hesitate.</h2>
        <ul>
          <li>Thin service descriptions</li>
          <li>No proof or local context</li>
          <li>Generic contact page</li>
          <li>Mobile layout feels unfinished</li>
        </ul>
      </article>
      <article class="comparison-card">
        <p class="eyebrow">Credibility website</p>
        <h2>Prospects know why to call.</h2>
        <ul>
          <li>Clear offer and service fit</li>
          <li>Trust points, reviews, and FAQs</li>
          <li>Direct calls to action</li>
          <li>Fast static pages with clean structure</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="content-section">
    <div class="container two-col">
      <div>
        <p class="eyebrow">Why it is worth it</p>
        <h2>Your website has to do sales work before anyone contacts you.</h2>
        <p>A stronger site reduces doubt, explains the value of your service, shows proof, and gives qualified prospects a low-friction next step. That is the difference between a brochure and a credibility asset.</p>
      </div>
      <div class="timeline-list">
        {processSteps.map((step, index) => (
          <article><span>0{index + 1}</span><strong>{step.title}</strong><p>{step.description}</p></article>
        ))}
      </div>
    </div>
  </section>

  <section class="content-section care-band">
    <div class="container split">
      <div>
        <p class="eyebrow">Ongoing support</p>
        <h2>Monthly care for edits, upkeep, and steady improvement.</h2>
        <p>After launch, care plans can cover content edits, new photos, seasonal updates, landing-page improvements, and priority support.</p>
      </div>
      <a class="button-primary" href={sitePath('offer-site/contact')}>Book a Website Launch Review</a>
    </div>
  </section>
</MarketingLayout>
