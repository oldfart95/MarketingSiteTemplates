---
import '../styles/global.css';
import { sitePath } from '../lib/paths';
const { business, pageTitle, pageDescription } = Astro.props;
const basePath = sitePath(`premium/${business.slug}`);
const navItems = [
  ['Home', `${basePath}/`],
  ['Services', `${basePath}/services`],
  ['Process', `${basePath}/process`],
  ['Pricing', `${basePath}/pricing`],
  ['Resources', `${basePath}/resources`],
  ['About', `${basePath}/about`],
  ['Contact', `${basePath}/contact`]
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle ?? business.seo.title}</title>
    <meta name="description" content={pageDescription ?? business.seo.description} />
  </head>
  <body class={`theme-${business.templateType} premium-site`} style={`--brand:${business.theme.primary};--cta:${business.theme.secondary};--accent:${business.theme.accent};--surface:${business.theme.surface};`}>
    <header class="site-header premium-header">
      <div class="top-strip">
        <div class="container top-strip__inner">
          <span>{business.city}</span>
          <span>{business.premium.hours}</span>
        </div>
      </div>
      <div class="container header-main">
        <a class="brand" href={`${basePath}/`} aria-label={`${business.businessName} home`}>
          <span class="brand-mark">{business.businessName.charAt(0)}</span>
          <span>
            <strong>{business.businessName}</strong>
            <small>{business.tagline}</small>
          </span>
        </a>
        <div class="header-actions">
          <a href={`${basePath}/pricing`} class="button button--ghost">Compare Packages</a>
          <a href={`tel:${business.phone}`} class="button button--solid">{business.phone}</a>
        </div>
      </div>
      <nav class="container nav" aria-label="Premium navigation">
        {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-grid premium-footer-grid">
        <div>
          <strong>{business.businessName}</strong>
          <p>{business.address}</p>
        </div>
        <div>
          <strong>Service Area</strong>
          <p>{business.serviceArea.join(', ')}</p>
        </div>
        <div>
          <strong>Next Step</strong>
          <p><a href={`${basePath}/contact`}>{business.primaryCTA}</a><br /><a href={`mailto:${business.email}`}>{business.email}</a></p>
        </div>
      </div>
    </footer>
  </body>
</html>
