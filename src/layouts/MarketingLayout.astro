---
import '../styles/global.css';
import { sitePath } from '../lib/paths';
import { offerSiteConfig } from '../data/offer-site';
const {
  title = 'FrontDoor Web Co.',
  description = 'Credible websites for local businesses people need to trust.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="marketing-header">
      <div class="container nav-wrap">
        <a href={sitePath()} class="brand">FrontDoor Web Co.</a>
        <nav aria-label="Primary navigation" class="nav-links">
          <a href={sitePath('offer-site/services')}>Services</a>
          <a href={sitePath('offer-site/examples')}>Examples</a>
          <a href={sitePath('offer-site/pricing')}>Pricing</a>
          <a href={sitePath('offer-site/process')}>Process</a>
          <a href={sitePath('offer-site/faq')}>FAQ</a>
          <a href={sitePath('offer-site/contact')} class="nav-cta">Start Project</a>
        </nav>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="marketing-footer">
      <div class="container marketing-footer-grid">
        <div>
          <strong>FrontDoor Web Co.</strong>
          <p>Credible websites for local businesses people need to trust.</p>
          <p>{offerSiteConfig.serviceArea}</p>
        </div>
        <div>
          <strong>Work directly with the builder</strong>
          <p>{offerSiteConfig.founderLine}</p>
        </div>
        <div>
          <strong>Start here</strong>
          <p><a href={sitePath('offer-site/contact')}>Book a Website Review</a><br /><a href={sitePath('demo-library/')}>Browse sample builds</a></p>
        </div>
      </div>
    </footer>
  </body>
</html>
